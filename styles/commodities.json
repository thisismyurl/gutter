{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Commodities",
  "settings": {
    "custom": {
      "colophon-light": "#f5f2e8",
      "colophon-dark": "#1a1714",
      "colophon-accent": "#6e5210"
    },
    "color": {
      "palette": [
        {
          "slug": "ink-deep",
          "color": "#1a1714",
          "name": "Ink Deep"
        },
        {
          "slug": "ink-primary",
          "color": "#2a2420",
          "name": "Ink Primary"
        },
        {
          "slug": "ink-muted",
          "color": "#5f564a",
          "name": "Ink Muted"
        },
        {
          "slug": "ink-faint",
          "color": "#b8b0a4",
          "name": "Ink Faint"
        },
        {
          "slug": "rule",
          "color": "#d8d0c4",
          "name": "Rule"
        },
        {
          "slug": "rule-light",
          "color": "#ece8e0",
          "name": "Rule Light"
        },
        {
          "slug": "ground",
          "color": "#f5f2e8",
          "name": "Ground"
        },
        {
          "slug": "paper",
          "color": "#fdf8f0",
          "name": "Paper"
        },
        {
          "slug": "white",
          "color": "#ffffff",
          "name": "White"
        },
        {
          "slug": "accent",
          "color": "#6e5210",
          "name": "Accent"
        },
        {
          "slug": "accent-tint",
          "color": "#f5e8c0",
          "name": "Accent Tint"
        },
        {
          "slug": "positive",
          "color": "#1E6E2B",
          "name": "Positive"
        },
        {
          "slug": "negative",
          "color": "#B82626",
          "name": "Negative"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--ground)",
      "text": "var(--wp--preset--color--ink-primary)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--ink-deep)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--white)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink-primary)"
        }
      }
    }
  }
}