{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Night Report",
  "settings": {
    "custom": {
      "colophon-light": "#070c14",
      "colophon-dark": "#d8e0ec",
      "colophon-accent": "#33b88c"
    },
    "color": {
      "palette": [
        {
          "slug": "ink-deep",
          "color": "#d8e0ec",
          "name": "Ink Deep"
        },
        {
          "slug": "ink-primary",
          "color": "#c0c8d8",
          "name": "Ink Primary"
        },
        {
          "slug": "ink-muted",
          "color": "#98a6bc",
          "name": "Ink Muted"
        },
        {
          "slug": "ink-faint",
          "color": "#4e5a72",
          "name": "Ink Faint"
        },
        {
          "slug": "rule",
          "color": "#2a3850",
          "name": "Rule"
        },
        {
          "slug": "rule-light",
          "color": "#141e30",
          "name": "Rule Light"
        },
        {
          "slug": "ground",
          "color": "#070c14",
          "name": "Ground"
        },
        {
          "slug": "paper",
          "color": "#0e1520",
          "name": "Paper"
        },
        {
          "slug": "white",
          "color": "#0e1520",
          "name": "White"
        },
        {
          "slug": "accent",
          "color": "#33b88c",
          "name": "Accent"
        },
        {
          "slug": "accent-tint",
          "color": "#0a2820",
          "name": "Accent Tint"
        },
        {
          "slug": "positive",
          "color": "#2aaa6a",
          "name": "Positive"
        },
        {
          "slug": "negative",
          "color": "#ff6b6b",
          "name": "Negative"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--ground)",
      "text": "var(--wp--preset--color--ink-deep)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--accent)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--ink-deep)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--accent)",
          "text": "var(--wp--preset--color--ground)"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--ink-deep)",
            "text": "var(--wp--preset--color--ground)"
          }
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--ink-deep)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--ink-primary)"
        }
      }
    }
  }
}
